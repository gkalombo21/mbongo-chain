# Server Configuration
PORT=8080
HOST=localhost

# Node Environment
NODE_ENV=development

# Database Configuration
DB_URL=postgresql://localhost:5432/mbongo_chain?sslmode=disable
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mbongo_chain
DB_USER=mbongo_user
DB_PASSWORD=change_me

# Blockchain Configuration
CHAIN_ID=mbongo-chain-1
NODE_RPC_URL=http://localhost:26657
NODE_GRPC_URL=http://localhost:9090

# API Configuration
API_ENABLED=true
API_PORT=1317
REST_API_PORT=8080
GRPC_PORT=9090

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Cosmos SDK Configuration
COSMOS_SDK_VERSION=v0.50.0
APP_NAME=mbongo-chain

# Security
SECRET_KEY=change_this_secret_key_in_production
JWT_SECRET=change_this_jwt_secret_in_production

# GPU Mining Configuration (PoUW)
GPU_WORKER_ENABLED=false
GPU_WORKER_PORT=8081
GPU_MINIMUM_MEMORY=4096

# CORS Configuration
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Monitoring
METRICS_ENABLED=false
METRICS_PORT=9091